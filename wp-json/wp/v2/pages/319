nction updateScrollShrink() {\n      const viewportH = window.innerHeight;\n      const currentScrollY = window.scrollY || window.pageYOffset;\n\n      items.forEach((el) => {\n        const parent = el.parentElement;\n        if (!parent) return;\n\n        const rect = parent.getBoundingClientRect();\n        const styles = getComputedStyle(el);\n\n        const widthFrom = parseFloat(styles.getPropertyValue('--width-from')) || 100;\n        const widthTo = parseFloat(styles.getPropertyValue('--width-to')) || 80;\n\n        const heightFromVh = parseFloat(styles.getPropertyValue('--height-from')) || 100;\n        const heightToVh = parseFloat(styles.getPropertyValue('--height-to')) || 60;\n\n        const radiusFrom = parseFloat(styles.getPropertyValue('--radius-from')) || 0;\n        const radiusTo = parseFloat(styles.getPropertyValue('--radius-to')) || 1.25;\n\n        const shrinkDistance = parseFloat(styles.getPropertyValue('--shrink-distance')) || 420;\n        const triggerPoint = parseFloat(styles.getPropertyValue('--trigger-point')) || 1.00;\n\n        const triggerY = viewportH * triggerPoint;\n\n        \/*\n          Guardamos el scrollY exacto cuando el padre entra al punto de inicio.\n          As\u00ed el efecto empieza desde 0 aunque el bloque ya sea visible.\n        *\/\n        if (!el.dataset.shrinkStartY && rect.top <= triggerY) {\n          el.dataset.shrinkStartY = String(currentScrollY);\n        }\n\n        let progress = 0;\n\n        if (el.dataset.shrinkStartY) {\n          const startY = parseFloat(el.dataset.shrinkStartY) || 0;\n          progress = clamp((currentScrollY - startY) \/ shrinkDistance, 0, 1);\n        }\n\n        const currentWidth = widthFrom + (widthTo - widthFrom) * progress;\n        const currentHeightVh = heightFromVh + (heightToVh - heightFromVh) * progress;\n        const currentHeightPx = (currentHeightVh \/ 100) * viewportH;\n        const currentRadius = radiusFrom + (radiusTo - radiusFrom) * progress;\n\n   