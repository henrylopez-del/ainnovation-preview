] = Caracter\u00edsticas\n    \/\/ headers[1...] = nombres de planes\n    for (let colIndex = 1; colIndex < headers.length; colIndex++) {\n      const planName = headers[colIndex];\n\n      let rowsHtml = '';\n\n      bodyRows.forEach((row) => {\n        const cells = row.querySelectorAll('th, td');\n        const feature = cells[0] ? cells[0].innerHTML.trim() : '';\n        const value = cells[colIndex] ? cells[colIndex].innerHTML.trim() : '';\n\n        rowsHtml += `\n          <tr>\n            <th>${feature}<\/th>\n            <td>${value}<\/td>\n          <\/tr>\n        `;\n      });\n\n      const card = document.createElement('div');\n      card.className = 'plan-mobile-card';\n\n      card.innerHTML = `\n        <table class=\"plan-mobile-table\">\n          <thead>\n            <tr>\n              <th>Caracter\u00edsticas<\/th>\n              <th>${planName}<\/th>\n            <\/tr>\n          <\/thead>\n          <tbody>\n            ${rowsHtml}\n          <\/tbody>\n        <\/table>\n      `;\n\n      mobileContainer.appendChild(card);\n    }\n  }\n\n  buildMobileTables();\n  window.addEventListener('resize', buildMobileTables);\n});\n<\/script>\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-5f6b033 e-flex e-con-boxed e-con e-parent\" data-id=\"5f6b033\" data-element_type=\"container\" data-e-type=\"container\" data-settings=\"{&quot;background_background&quot;:&quot;classic&quot;}\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-cdd6adc e-con-full e-flex e-con e-child\" data-id=\"cdd6adc\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-4f46b53 elementor-widget elementor-widget-heading\" data-id=\"4f46b53\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default